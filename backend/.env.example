# ====== 数据库配置 ======
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=ai_interview

# ====== Redis配置 ======
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ====== DeepSeek V4 API ======
# 从 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=sk-your-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ====== JWT配置 ======
# 使用 python -c "import secrets; print(secrets.token_hex(32))" 生成随机密钥
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ====== 文件上传 ======
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
